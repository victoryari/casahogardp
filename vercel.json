{
    "version": 2,
    "framework": null,
    "outputDirectory": ".",
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "routes": [
        {
            "src": "/(css|js|images|favicon.ico)(.*)",
            "dest": "/public/$1$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_URL": "https://casahogardp.vercel.app",
        "APP_KEY": "base64:YOUR_APP_KEY_HERE",
        "DB_CONNECTION": "mysql",
        "DB_HOST": "YOUR_DB_HOST",
        "DB_PORT": "3306",
        "DB_DATABASE": "YOUR_DB_NAME",
        "DB_USERNAME": "YOUR_DB_USER",
        "DB_PASSWORD": "YOUR_DB_PASSWORD"
    }
}
